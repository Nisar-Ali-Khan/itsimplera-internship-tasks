{
  "info": {
    "name": "Ledger — Task Management API",
    "description": "Secure Multi-User Task Management API with JWT Authentication. Covers all endpoints required for the ITSimplera Full Stack Web Development Internship — Week 2 Task.\n\nHow to use:\n1. Import this collection and the accompanying environment.\n2. Run \"Register\" or \"Login\" first — both automatically save the returned JWT into the {{token}} variable via their response scripts.\n3. All other requests use {{token}} automatically via Bearer auth inherited from the collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" },
    { "key": "taskId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('token', data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('token', data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout"
          }
        },
        {
          "name": "Get Current User (/auth/me)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/users/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"bio\": \"Full Stack Developer\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/users/change-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"secret123\",\n  \"newPassword\": \"newSecret456\"\n}"
            }
          }
        },
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/dashboard-stats"
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/tasks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Prepare client presentation\",\n  \"description\": \"Slides for Monday's kickoff\",\n  \"priority\": \"High\",\n  \"status\": \"Pending\",\n  \"dueDate\": \"2026-07-10\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('taskId', data.task._id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Tasks (search/filter/sort/paginate)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tasks?search=&status=&priority=&sort=-dueDate&page=1&limit=8",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                { "key": "search", "value": "" },
                { "key": "status", "value": "" },
                { "key": "priority", "value": "" },
                { "key": "sort", "value": "-dueDate" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "8" }
              ]
            }
          }
        },
        {
          "name": "Get Task By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks/{{taskId}}"
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/tasks/{{taskId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"In Progress\"\n}"
            }
          }
        },
        {
          "name": "Delete Task (soft delete)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/tasks/{{taskId}}"
          }
        },
        {
          "name": "Get Trashed Tasks",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/tasks/trash"
          }
        },
        {
          "name": "Restore Task",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/tasks/{{taskId}}/restore"
          }
        }
      ]
    }
  ]
}
